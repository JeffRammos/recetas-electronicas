// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  ADMIN
  PROFESIONAL
}

enum EstadoProfesional {
  PENDIENTE
  APROBADO
}

model Usuario {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  nombre       String
  rol          Rol
  createdAt    DateTime     @default(now())
  profesional  Profesional?
}

model Profesional {
  id           String            @id @default(cuid())
  usuario      Usuario           @relation(fields: [usuarioId], references: [id])
  usuarioId    String            @unique
  especialidad String?
  matricula    String?
  firmaPath    String?
  estado       EstadoProfesional @default(PENDIENTE)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model Medicamento {
  id              String   @id @default(cuid())
  nombre          String   @unique
  vencimientoDias Int      @default(30)
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model Estudio {
  id              String   @id @default(cuid())
  nombre          String   @unique
  vencimientoDias Int      @default(60)
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model ObraSocial {
  id                          String   @id @default(cuid())
  nombre                      String   @unique
  // null = usa el vencimientoDias del medicamento/estudio; si tiene valor, lo pisa.
  vencimientoMedicamentosDias Int?
  vencimientoEstudiosDias     Int?
  activo                      Boolean  @default(true)
  createdAt                   DateTime @default(now())
}
